{
  "name": "doget-chrome-extension",
  "version": "1.0.0",
  "private": true,
  "description": "Right-click any download link to accelerate it via DoGet. Chrome Extension (Manifest V3).",
  "scripts": {
    "lint": "eslint src/ scripts/",
    "format": "prettier --write \"**/*.{js,html,css,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,html,css,json,md}\"",
    "build": "node scripts/build.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0"
  },
  "keywords": [
    "chrome-extension",
    "doget",
    "download-accelerator",
    "github-release",
    "manifest-v3"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/weisha1991/doget-chrome-extension.git"
  }
}
